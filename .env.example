# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
WS_HOST=0.0.0.0
WS_PORT=8765

# 数据库
DATABASE_URL=sqlite:///./moner.db
# DATABASE_URL=postgresql://user:password@localhost/moner

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# 工具安全限制
ALLOWED_BASH_PATHS=/home/jayson2013/moner,/tmp
MAX_BASH_TIMEOUT=30
ALLOWED_READ_PATHS=/home/jayson2013/moner
ALLOWED_EDIT_PATHS=/home/jayson2013/moner

